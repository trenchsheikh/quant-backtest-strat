# MT5 connection — fill from competition portal
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=CompetitionBroker-Live

# Bridge
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8765

# === SAFETY: must be explicitly true to send real orders ===
ENTRY_ENABLED=false

# Logfire token (omit to log to stderr only)
LOGFIRE_TOKEN=

# State persistence directory
STATE_DIR=./live_state

# Historical bars to seed on startup
HISTORY_BARS=300

# BTC scalp (see live/README.md) — 0 = auto TP/SL from per-lot medians
SCALP_LOT_BTC=0.1
